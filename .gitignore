# Dependencies
node_modules/
.bun/

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment & secrets
.env
.env.*
!.env.example
.env.*.local

# Conductor runtime data
.conductor/data/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Personal/live Conductor configs (never commit a real project's config -
