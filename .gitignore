/.conductor.yml
!/.conductor.example.yml

# Stray local artifact from testing example-file compilation against a
# real project - not part of the tracked tree
/packages/farsight/

# Electron desktop app build artifacts
packages/desktop/dist/
packages/desktop/out/
packages/core/dist-bin/

# Logs
*.log
/logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Test coverage
coverage/

# Vite
.vite/
*.local
