{
  "name": "@conductor/core",
  "version": "0.1.0",
  "private": true,
  "description": "Conductor core engine: config, executor, logger, database, API",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun run --watch bin/server.ts",
    "build": "bun build ./bin/server.ts --outdir dist --target bun",
    "build:sidecar": "bun build ./bin/server.ts --compile --outfile dist-bin/conductor-server",
    "start": "bun run dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/static": "^10.1.0",
    "fastify": "^5.10.0",
    "js-yaml": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
