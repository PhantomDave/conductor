{
  "name": "@conductor/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Conductor desktop app: an Electron shell around the core API + web dashboard",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "esbuild src/main.ts --bundle --platform=node --format=cjs --outfile=dist/main.js --external:electron",
    "typecheck": "tsc --noEmit",
    "dev": "bun run build:main && electron .",
    "dist": "bun run build:main && electron-builder",
    "release": "bun run build:main && electron-builder --publish always"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
